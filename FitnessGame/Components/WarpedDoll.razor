@using System.Net.Http.Json
@using System.Text.Json.Serialization
@using System.Globalization
@inject HttpClient Http
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="warped-doll">
    <canvas id="@_canvasId" width="280" height="560" class="doll-canvas"></canvas>
</div>

@if (ShowDebug && _mesh is not null)
{
    <div class="warp-debug">
        <div class="warp-debug-head">Morph debug</div>
        @foreach (var g in _mesh.MorphGroups)
        {
            var key = g.Id;
            <div class="warp-row warp-row-1">
                <span class="warp-label">@key</span>
                <label>expand
                    <input type="range" min="-0.10" max="0.10" step="0.002"
                           value="@F(_debugExpand.GetValueOrDefault(key))"
                           @oninput="e => OnDebug(key, e.Value)" />
                    <span>@F(_debugExpand.GetValueOrDefault(key))</span>
                </label>
            </div>
        }
        <button class="link-btn" @onclick="ResetDebug">Reset sliders</button>
    </div>
}

@code {
    [Parameter, EditorRequired] public Stats S { get; set; } = new();
    [Parameter] public bool ShowDebug { get; set; }

    const int GridN = 120;
    readonly string _canvasId = "warped-doll-" + Guid.NewGuid().ToString("N")[..8];

    IJSObjectReference? _module;
    MeshData? _mesh;
    bool _initialized;

    readonly Dictionary<string, double> _debugExpand = new();

    // Buffer reused each frame.
    double[]? _verts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _mesh = await LoadMeshNoCache()
                ?? throw new InvalidOperationException("Failed to load Alice.data.json");

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/warp.js");
        await _module.InvokeAsync<object>("init", _canvasId, "assets/Alice.png");

        _initialized = true;
        StateHasChanged(); // show the debug panel now that _mesh is populated
        await Redraw();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized) await Redraw();
    }

    async Task<MeshData?> LoadMeshNoCache()
    {
        var url = $"assets/Alice.data.json?t={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
        var req = new HttpRequestMessage(HttpMethod.Get, url);
        req.SetBrowserRequestCache(BrowserRequestCache.NoStore);
        req.Headers.CacheControl = new System.Net.Http.Headers.CacheControlHeaderValue
        {
            NoCache = true, NoStore = true, MustRevalidate = true
        };
        var resp = await Http.SendAsync(req);
        resp.EnsureSuccessStatusCode();
        return await resp.Content.ReadFromJsonAsync<MeshData>();
    }

    async Task Redraw()
    {
        if (_module is null || _mesh is null) return;

        // 1) Compute current per-control-point offsets from Stats + debug sliders.
        var cps = BuildControlPoints();

        // 2) Build warped vertex grid.
        var stride = GridN + 1;
        _verts ??= new double[stride * stride * 2];
        for (int j = 0; j <= GridN; j++)
        {
            double v = (double)j / GridN;
            for (int i = 0; i <= GridN; i++)
            {
                double u = (double)i / GridN;
                var (dx, dy) = Warp(u, v, cps);
                int k = (j * stride + i) * 2;
                _verts[k] = u + dx;
                _verts[k + 1] = v + dy;
            }
        }

        await _module.InvokeVoidAsync("render", _canvasId, _verts, GridN);
    }

    // ---- Stats -> per-group "expand" amount in normalized image space.
    // Positive values puff the region outward; negative values pull it in.
    // Mirrors the silhouette logic from the old PaperDoll.
    double GroupExpand(string id) => id switch
    {
        "breast" => (S.Bust - 45) * 0.0010,
        "waist"  => (S.BodyFat - 24) * 0.0018 - (S.AbsTone - 25) * 0.0008,
        "abs"    => -(S.AbsTone - 25) * 0.0008,
        "hips"   => (S.BodyFat - 24) * 0.0020 + (S.GluteTone - 30) * 0.0014,
        "thighs" => (S.BodyFat - 24) * 0.0020 + (S.LegsTone - 25) * 0.0008,
        "calves" => (S.BodyFat - 24) * 0.0010 + (S.LegsTone - 25) * 0.0006,
        _ => 0
    };

    List<Cp> BuildControlPoints()
    {
        var list = new List<Cp>();
        if (_mesh is null) return list;

        foreach (var g in _mesh.MorphGroups)
        {
            var expand = GroupExpand(g.Id) + _debugExpand.GetValueOrDefault(g.Id);
            foreach (var cp in g.ControlPoints)
            {
                list.Add(new Cp(cp.X, cp.Y, expand, cp.BaseWeight, cp.InfluenceRadius));
            }
        }

        foreach (var a in _mesh.StaticAnchors)
        {
            // Pin: zero expansion, modest weight, generous radius so head/arms/feet stay put.
            list.Add(new Cp(a.X, a.Y, 0, 1.5, 0.18));
        }
        return list;
    }

    static double Smoothstep(double t)
    {
        t = Math.Clamp(t, 0, 1);
        return t * t * (3 - 2 * t);
    }

    // Radial expansion warp: each control point pushes its neighborhood
    // outward along the radial direction (toward the vertex) by `expand`,
    // weighted by the smoothstep falloff. Static anchors (expand=0) cancel
    // motion in their neighborhood by contributing weight with zero push,
    // dragging the weighted average back toward zero.
    static (double dx, double dy) Warp(double x, double y, IList<Cp> cps)
    {
        double wx = 0, wy = 0, ws = 0;
        foreach (var c in cps)
        {
            double ddx = x - c.X, ddy = y - c.Y;
            double d = Math.Sqrt(ddx * ddx + ddy * ddy);
            double t = d / c.Radius;
            if (t >= 1) continue;
            double w = c.Weight * (1 - Smoothstep(t));
            if (c.Expand != 0 && d > 1e-6)
            {
                double inv = 1.0 / d;
                wx += w * c.Expand * ddx * inv;
                wy += w * c.Expand * ddy * inv;
            }
            ws += w;
        }
        return ws > 1e-6 ? (wx / ws, wy / ws) : (0, 0);
    }

    void OnDebug(string key, object? raw)
    {
        if (!double.TryParse(raw?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var v)) return;
        _debugExpand[key] = v;
        _ = Redraw();
    }

    void ResetDebug()
    {
        _debugExpand.Clear();
        _ = Redraw();
    }

    static string F(double v) => v.ToString("0.000", CultureInfo.InvariantCulture);

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
        }
    }

    record Cp(double X, double Y, double Expand, double Weight, double Radius);

    class MeshData
    {
        [JsonPropertyName("morph_groups")] public List<MorphGroup> MorphGroups { get; set; } = new();
        [JsonPropertyName("static_anchors")] public List<Anchor> StaticAnchors { get; set; } = new();
    }
    class MorphGroup
    {
        [JsonPropertyName("id")] public string Id { get; set; } = "";
        [JsonPropertyName("control_points")] public List<ControlPoint> ControlPoints { get; set; } = new();
    }
    class ControlPoint
    {
        [JsonPropertyName("side")] public string Side { get; set; } = "center";
        [JsonPropertyName("x")] public double X { get; set; }
        [JsonPropertyName("y")] public double Y { get; set; }
        [JsonPropertyName("base_weight")] public double BaseWeight { get; set; } = 1;
        [JsonPropertyName("influence_radius")] public double InfluenceRadius { get; set; } = 0.1;
    }
    class Anchor
    {
        [JsonPropertyName("x")] public double X { get; set; }
        [JsonPropertyName("y")] public double Y { get; set; }
    }
}
