@page "/"
@inject GameEngine Engine
@implements IDisposable

<PageTitle>Model Trainer — fitness simulator</PageTitle>

<div class="game-shell">
    <header class="topbar">
        <h1>Model Trainer</h1>
        <div class="day">Day <strong>@Engine.Stats.Day</strong></div>
        <a class="reset" href="/calibrate" title="Calibrate mesh anchors" style="margin-right:8px;">⚙ Calibrate</a>
        <button class="reset" @onclick="Engine.Reset" title="Restart">↺ Restart</button>
    </header>

    <div class="game-layout">

        <!-- Left: paper doll + headline numbers -->
        <section class="doll-panel">
            <div class="commit commit-top">
                <button class="primary" disabled="@( _activity is null || _foods.Count == 0)" @onclick="Commit">
                    End the day →
                </button>
            </div>
            <WarpedDoll S="Engine.Stats" ShowDebug="true" />
            <div class="doll-tagline">
                <span class="ig">@@you_get_fit</span>
                <span class="followers">@FormatFollowers(Engine.Stats.Followers) followers</span>
            </div>
        </section>

        <!-- Middle: stats -->
        <section class="stats-panel">
            <h2>Body</h2>
            <StatBar Label="Weight"      Value="@Engine.Stats.Weight"     Unit="kg" Min="40" Max="120" Color="#76a9ff" />
            <StatBar Label="Body fat"    Value="@Engine.Stats.BodyFat"    Unit="%"  Min="6"  Max="50"  Color="#ff8a4a" Invert="true" />
            <StatBar Label="Muscle mass" Value="@Engine.Stats.MuscleMass" Unit="kg" Min="10" Max="50"  Color="#ff4d7e" />
            <StatBar Label="Bust"        Value="@Engine.Stats.Bust"       Max="100" Color="#ff7ab6" />

            <h2>Performance</h2>
            <StatBar Label="Strength"    Value="@Engine.Stats.Strength"    Max="100" Color="#e6b500" />
            <StatBar Label="Endurance"   Value="@Engine.Stats.Endurance"   Max="100" Color="#36c98f" />
            <StatBar Label="Flexibility" Value="@Engine.Stats.Flexibility" Max="100" Color="#9b6cff" />

            <h2>Condition</h2>
            <StatBar Label="Energy"      Value="@Engine.Stats.Energy"      Max="100" Color="#ffd24a" />
            <StatBar Label="Mood"        Value="@Engine.Stats.Mood"        Max="100" Color="#ff7ab6" />
            <StatBar Label="Health"      Value="@Engine.Stats.Health"      Max="100" Color="#7ed957" />

            <h2>Muscle tone</h2>
            <StatBar Label="Chest" Value="@Engine.Stats.ChestTone" Max="100" Color="#ff4d7e" Slim="true" />
            <StatBar Label="Back"  Value="@Engine.Stats.BackTone"  Max="100" Color="#ff4d7e" Slim="true" />
            <StatBar Label="Arms"  Value="@Engine.Stats.ArmsTone"  Max="100" Color="#ff4d7e" Slim="true" />
            <StatBar Label="Abs"   Value="@Engine.Stats.AbsTone"   Max="100" Color="#ff4d7e" Slim="true" />
            <StatBar Label="Legs"  Value="@Engine.Stats.LegsTone"  Max="100" Color="#ff4d7e" Slim="true" />
            <StatBar Label="Glutes" Value="@Engine.Stats.GluteTone" Max="100" Color="#ff4d7e" Slim="true" />
        </section>

        <!-- Right: choices + log -->
        <section class="choices-panel">
            <h2>1. Pick your activity</h2>
            <div class="grid grid-activities">
                @foreach (var a in Activity.All)
                {
                    var isSel = _activity?.Kind == a.Kind;
                    <button class="card @(isSel ? "selected" : "")" @onclick="() => _activity = a" title="@a.Description">
                        <span class="emoji">@a.Emoji</span>
                        <span class="name">@a.Name</span>
                        <span class="sub">@(a.CaloriesBurned) kcal</span>
                    </button>
                }
            </div>

            <h2>2. Pick meals for the day</h2>
            <p class="meal-hint">Tap to add/remove. Stack multiple meals to hit your calorie target.</p>
            @foreach (var tier in Enum.GetValues<FoodTier>())
            {
                <div class="tier">
                    <div class="tier-label tier-@tier.ToString().ToLower()">@tier</div>
                    <div class="grid grid-foods">
                        @foreach (var f in Food.All.Where(x => x.Tier == tier))
                        {
                            var isSel = _foods.Any(x => x.Name == f.Name);
                            <button class="card @(isSel ? "selected" : "")" @onclick="() => ToggleFood(f)" title="@f.Description">
                                <span class="emoji">@f.Emoji</span>
                                <span class="name">@f.Name</span>
                                <span class="sub">@f.Calories kcal · @f.Protein P · @f.Carbs C · @f.Fat F</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="meal-summary">
                @{
                    var totalCal = _foods.Sum(f => f.Calories);
                    var totalProtein = _foods.Sum(f => f.Protein);
                    var burn = _activity?.CaloriesBurned ?? 0;
                    var balance = totalCal - burn;
                }
                <div>
                    <strong>@_foods.Count meal@(_foods.Count == 1 ? "" : "s")</strong>
                    · @totalCal kcal in
                    @if (_activity is not null)
                    {
                        <span> · @burn kcal out · balance <span class="@(balance < -200 ? "neg" : balance > 200 ? "pos" : "even")">@(balance > 0 ? "+" : "")@balance kcal</span></span>
                    }
                    · @totalProtein g protein
                </div>
                @if (_foods.Count > 0)
                {
                    <button class="link-btn" @onclick="() => _foods.Clear()">Clear meals</button>
                }
            </div>

            @if (Engine.LastTurn is { } turn)
            {
                <div class="log">
                    <h2>Yesterday</h2>
                    <p class="log-summary">
                        <strong>@turn.Activity.Emoji @turn.Activity.Name</strong>
                        + <strong>@FormatFoods(turn.Foods)</strong>
                        · @(turn.Delta > 0 ? "+" : "")@turn.Delta kcal balance
                    </p>
                    <ul>
                        @foreach (var line in turn.Log)
                        {
                            <li>@line</li>
                        }
                    </ul>
                </div>
            }
        </section>
    </div>
</div>

@code {
    private Activity? _activity;
    private readonly List<Food> _foods = new();

    protected override void OnInitialized()
    {
        Engine.Changed += OnChanged;
    }

    public void Dispose() => Engine.Changed -= OnChanged;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private void ToggleFood(Food f)
    {
        var existing = _foods.FindIndex(x => x.Name == f.Name);
        if (existing >= 0) _foods.RemoveAt(existing);
        else _foods.Add(f);
    }

    private void Commit()
    {
        if (_activity is null || _foods.Count == 0) return;
        Engine.AdvanceDay(_activity, _foods);
        _activity = null;
        _foods.Clear();
    }

    private static string FormatFoods(IReadOnlyList<Food> foods)
    {
        if (foods.Count == 0) return "";
        return string.Join(" + ", foods.Select(f => $"{f.Emoji} {f.Name}"));
    }

    private static string FormatFollowers(int n)
    {
        if (n >= 1_000_000) return $"{n / 1_000_000.0:0.0}M";
        if (n >= 1_000) return $"{n / 1_000.0:0.0}K";
        return n.ToString();
    }
}
